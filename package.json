{
  "name": "savolalab",
  "description": "Laboratory Information Management System for Savola",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server/server.ts",
    "build": "vite build --mode production",
