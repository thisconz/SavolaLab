{
  "name": "zenthar",
  "description": "Laboratory Information Management System — Enterprise QC Platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch server/server.ts",
    "dev:ui": "vite",
    "dev:fullstack": "concurrently \"npm run dev\" \"npm run dev:ui\"",
    "prebuild": "npm run clean && npm run type-check",
    "build": "vite build --mode production",
    "build:server": "tsx scripts/build-server.ts",
    "start": "NODE_ENV=production node dist/server/server.js",
    "clean": "rimraf dist .next .turbo",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen": "npm run gen:types && npm run gen:structure",
    "gen:types": "tsx scripts/index.ts types",
    "gen:structure": "tsx scripts/index.ts structure",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "update-deps": "npx npm-check-updates -u"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@hono/node-server": "^1.13.0",
    "@sentry/react": "^10.45.0",
    "argon2": "^0.44.0",
    "better-auth": "^1.5.6",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.33.0",
    "exceljs": "^4.3.0",
    "framer-motion": "^11.0.0",
    "hono": "^4.12.9",
    "hono-rate-limiter": "^0.5.3",
    "lucide-react": "^1.7.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.12.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.0",
    "uuid": "^13.0.0",
    "xstate": "^5.28.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/ui": "^3.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.24.0",
    "eslint": "^10.3.0",
    "eslint-plugin-regexp": "^3.1.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "rimraf": "^6.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.2.0",
    "vite-plugin-compression": "^0.5.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thisconz/Zenthar.git"
  },
  "keywords": [
    "lims",
    "laboratory",
    "qc",
    "sugar-refinery",
    "enterprise",
    "typescript",
    "hono"
  ],
  "author": "Zenthar Core Team",
  "license": "ISC"
}
